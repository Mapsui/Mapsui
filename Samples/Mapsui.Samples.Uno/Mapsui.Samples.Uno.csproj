<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net9.0-desktop</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>Mapsui.Samples.Uno</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>com.companyname.mapsui-samples-uno</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>Mapsui.Samples.Uno</ApplicationPublisher>
    <!-- Package Description -->
    <Description>Mapsui.Samples.Uno powered by Uno Platform.</Description>

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <UnoFeatures>
      SkiaRenderer;
    </UnoFeatures>

    <UnoDisableHotDesign>true</UnoDisableHotDesign>
    <UnoDisableMCPSupport>true</UnoDisableMCPSupport>
  </PropertyGroup>

  <Target Name="MapsuiMinimalDisableDevServer" BeforeTargets="UnoImplicitPackages">
    <ItemGroup>
      <_UnoProjectSystemPackageReference Remove="@(_UnoProjectSystemPackageReference)" Condition="'%(Identity)' == 'Uno.Settings.DevServer'" />
      <_UnoProjectSystemPackageReference Remove="@(_UnoProjectSystemPackageReference)" Condition="'%(Identity)' == 'Uno.WinUI.DevServer'" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <ProjectReference Include="..\..\Mapsui.Experimental.Rendering.Skia\Mapsui.Experimental.Rendering.Skia.csproj" />
    <ProjectReference Include="..\..\Mapsui.UI.Uno.WinUI\Mapsui.UI.Uno.WinUI.csproj" />
    <ProjectReference Include="..\Mapsui.Samples.Common\Mapsui.Samples.Common.csproj" />
  </ItemGroup>

</Project>

