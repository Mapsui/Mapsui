{
	"metadata": [
		{
			"src": [
				{
					"src": "../../",
					"files": [
						"Mapsui/Mapsui.csproj",
						"Mapsui.ArcGis/Mapsui.ArcGis.csproj",
						"Mapsui.Extensions/Mapsui.Extensions.csproj",
						"Mapsui.Nts/Mapsui.Nts.csproj",
						"Mapsui.Rendering.Skia/Mapsui.Rendering.Skia.csproj",
						"Mapsui.Tiling/Mapsui.Tiling.csproj",
						"Mapsui.UI.Android/Mapsui.UI.Android.csproj",
						"Mapsui.UI.Avalonia/Mapsui.UI.Avalonia.csproj",
						"Mapsui.UI.Avalonia12/Mapsui.UI.Avalonia12.csproj",
						"Mapsui.UI.Blazor/Mapsui.UI.Blazor.csproj",
						"Mapsui.UI.Eto/Mapsui.UI.Eto.csproj",
						"Mapsui.UI.iOS/Mapsui.UI.iOS.csproj",
						"Mapsui.UI.Maui/Mapsui.UI.Maui.csproj",
						"Mapsui.UI.Uno.WinUI/Mapsui.UI.Uno.WinUI.csproj",
						"Mapsui.UI.Wpf/Mapsui.UI.Wpf.csproj"
					]
				}
			],
			"dest": "pages",
			"disableGitFeatures": false
		}
	],
  "build": {
    "cleanupCacheHistory": false,
    "content": [
      {
        "files": [
          "index.md",
          "pages/**.yml",
          "../codesamples/**.md"
        ]
      }
    ],
    "dest": "_site",
    "disableGitFeatures": false,
    "fileMetadataFiles": [],
    "globalMetadataFiles": [ "metadata.json" ],
    "keepFileLink": false,
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "postProcessors": [ "ExtractSearchIndex" ],
    "template": [ "default" ],
    "xrefService": [ "https://xref.docs.microsoft.com/query?uid={uid}" ]
  }
}
